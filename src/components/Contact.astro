---
interface Props {
  lang?: "es" | "en";
}
const { lang = "es" } = Astro.props;

const exploreLinksEs = [
  { name: "Inicio", href: "#inicio" },
  { name: "Sobre Mí", href: "#sobre-mi" },
  { name: "Proceso", href: "#proceso" },
  { name: "Stack", href: "#stack" },
  { name: "Proyectos", href: "#proyectos" },
];
const exploreLinksEn = [
  { name: "Home", href: "#inicio" },
  { name: "About", href: "#sobre-mi" },
  { name: "Process", href: "#proceso" },
  { name: "Stack", href: "#stack" },
  { name: "Projects", href: "#proyectos" },
];

const connectLinks = [
  { name: "LinkedIn", href: "https://www.linkedin.com/in/valentin-pignatelli-47b379275/" },
  { name: "GitHub", href: "https://github.com/valentinopign" },
  { name: "X", href: "https://x.com/lgn_valentino" },
  { name: "Email", href: "mailto:dev.valentinpignatelli@gmail.com" },
  { name: "CV ↓", href: "/CV-Valentin-Pignatelli.pdf" },
];

const copy = {
  es: {
    exploreLinks: exploreLinksEs,
    tagline: "Full Stack & AI Product Developer.",
    sub: "Sistemas de punta a punta, IA integrada donde suma.",
    openTo: "Open to — Full Stack · AI Engineering · Remoto / Híbrido BSAS",
    explore: "Explore",
    connect: "Connect",
    ready: "Ready for the<br />next product.",
    build: "Let's build. →",
    copied: "Email copiado ✓",
  },
  en: {
    exploreLinks: exploreLinksEn,
    tagline: "Full Stack & AI Product Developer.",
    sub: "End-to-end systems, AI integrated where it counts.",
    openTo: "Open to — Full Stack · AI Engineering · Remote / Hybrid BA",
    explore: "Explore",
    connect: "Connect",
    ready: "Ready for the<br />next product.",
    build: "Let's build. →",
    copied: "Email copied ✓",
  },
};
const t = lang === "en" ? copy.en : copy.es;
---
<section id="contacto" class="bg-flame text-ink border-t-2 border-ink pb-0 relative overflow-hidden flex flex-col justify-between min-h-dvh">
  <!-- Main Grid Container (Full Width) -->
  <div class="grid grid-cols-1 lg:grid-cols-3 border-b-2 border-ink bg-flame w-full">
    
    <!-- Top Left (Row 1, Col 1): Valentin Pignatelli Bio (Dark Box) -->
    <div class="lg:col-span-1 border-b-2 lg:border-r-2 border-ink flex flex-col justify-between bg-ink text-flame">
      <!-- Text Content -->
      <div class="p-[clamp(24px,4vw,36px)] flex-grow">
        <span class="text-[11px] tracking-[0.22em] uppercase font-mono text-flame/75 font-bold block mb-4">VALENTÍN PIGNATELLI</span>
        <h3 class="m-0 font-display font-black [font-variation-settings:'wght'_900,'wdth'_115] text-[clamp(26px,3.5vw,36px)] leading-[0.9] tracking-tight uppercase mb-6 text-flame">
          {t.tagline}
        </h3>
        <p class="m-0 text-[14px] leading-[1.5] text-flame/90 font-medium">
          {t.sub}
        </p>
      </div>
      <div class="px-[clamp(24px,4vw,36px)] pb-6 font-mono text-[11px] tracking-[0.15em] uppercase text-flame/90 font-bold">
        {t.openTo}
      </div>
      <!-- Barcode divider -->
      <div class="h-10 border-t-2 border-ink bg-ink" style="background: repeating-linear-gradient(90deg, #FF4D00, #FF4D00 2px, transparent 2px, transparent 5px);"></div>
    </div>

    <!-- Top Right (Row 1, Col 2 & 3): Links Grid -->
    <div class="lg:col-span-2 border-b-2 border-ink p-[clamp(24px,4vw,36px)] grid grid-cols-1 sm:grid-cols-2 gap-12 bg-flame">
      <!-- Explore Links -->
      <div class="flex flex-col gap-6">
        <span class="text-[11px] tracking-[0.22em] uppercase font-mono text-ink/55 font-bold">{t.explore}</span>
        <div class="flex flex-col gap-2.5">
          {t.exploreLinks.map((l) => (
            <a href={l.href} class="font-display font-black [font-variation-settings:'wght'_900,'wdth'_115] text-[clamp(26px,4vw,44px)] leading-[0.95] tracking-tight uppercase text-ink no-underline hover:underline hover:underline-offset-[10px] hover:decoration-[3px]">
              {l.name}
            </a>
          ))}
        </div>
      </div>

      <!-- Connect Links -->
      <div class="flex flex-col gap-6">
        <span class="text-[11px] tracking-[0.22em] uppercase font-mono text-ink/55 font-bold">{t.connect}</span>
        <div class="flex flex-col gap-2.5">
          {connectLinks.map((l) => (
            <a href={l.href}
               target={l.href.startsWith("mailto:") ? undefined : "_blank"}
               rel={l.href.startsWith("mailto:") ? undefined : "noopener noreferrer"}
               data-copy-email={l.href.startsWith("mailto:") ? l.href.replace("mailto:", "") : undefined}
               data-label={l.href.startsWith("mailto:") ? l.name : undefined}
               class="font-display font-black [font-variation-settings:'wght'_900,'wdth'_115] text-[clamp(26px,4vw,44px)] leading-[0.95] tracking-tight uppercase text-ink no-underline hover:underline hover:underline-offset-[10px] hover:decoration-[3px]">
              {l.name}
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Bottom Left (Row 2, Col 1): Philosophy & CTA -->
    <div class="lg:col-span-1 border-b-2 lg:border-b-0 lg:border-r-2 border-ink p-[clamp(24px,4vw,36px)] flex flex-col justify-between bg-flame text-ink">
      <div class="mb-8">
        <h3 class="m-0 font-display font-black [font-variation-settings:'wght'_900,'wdth'_115] text-[clamp(26px,3.5vw,36px)] leading-[0.9] tracking-tight uppercase mb-5" set:html={t.ready}>
        </h3>
        <span class="block font-display font-black text-[clamp(32px,4vw,48px)] leading-none text-ink/80" aria-hidden="true">↓</span>
      </div>
      <button type="button" id="copy-email"
              data-email="dev.valentinpignatelli@gmail.com" data-label={t.build} data-copied={t.copied}
              class="group relative w-full bg-ink text-bone font-mono text-[11px] tracking-[0.22em] uppercase py-4 px-6 text-center font-bold block transition-colors duration-180 hover:bg-bone hover:text-ink cursor-pointer border-0 select-none">
        <span class="absolute top-1 left-1 w-1.5 h-1.5 bg-bone transition-colors duration-180 group-hover:bg-ink"></span>
        <span class="absolute top-1 right-1 w-1.5 h-1.5 bg-bone transition-colors duration-180 group-hover:bg-ink"></span>
        <span class="absolute bottom-1 left-1 w-1.5 h-1.5 bg-bone transition-colors duration-180 group-hover:bg-ink"></span>
        <span class="absolute bottom-1 right-1 w-1.5 h-1.5 bg-bone transition-colors duration-180 group-hover:bg-ink"></span>
        <span id="copy-email-label">{t.build}</span>
      </button>
    </div>

    <!-- Bottom Right (Row 2, Col 2 & 3): Copyright & Branding Bar -->
    <div class="lg:col-span-2 p-[clamp(24px,4vw,36px)] flex flex-row flex-wrap items-center justify-center gap-[clamp(12px,2vw,20px)] bg-flame text-ink">
      <!-- Logo VP -->
      <div class="flex items-center text-ink">
        <!-- Stylized blocky VP logo SVG with TM symbol -->
        <svg viewBox="0 0 220 100" class="h-[clamp(44px,6vw,60px)] w-auto" fill="currentColor" aria-label="VP Logo">
          <path fill-rule="evenodd" clip-rule="evenodd" d="
            M 0 0 L 40 0 L 48 16 L 48 70 L 50 80 L 52 70 L 52 16 L 60 0 L 100 0 L 100 55 L 68 100 L 32 100 L 0 55 Z
            M 108 100 L 146 100 L 146 70 L 208 70 L 208 22 L 186 0 L 108 0 Z
            M 146 22 H 170 V 48 H 146 Z
          " />
          <path d="
            M 186 85 H 198 V 88 H 193 V 100 H 190 V 88 H 186 Z
            M 200 100 V 85 H 204 L 207 92 L 210 85 H 214 V 100 H 211 V 90 L 207 97 L 203 90 V 100 Z
          " />
        </svg>
      </div>

      <!-- Combined Block (Cooling Fins/Barcode + Copyright Text) - Almost touching -->
      <div class="flex flex-row items-center gap-[clamp(4px,1vw,8px)]">
        <!-- Cooling Fins / Barcode Logo (Thicker: 3px bars, 1px gaps) -->
        <div class="flex items-center text-ink">
          <svg viewBox="0 0 40 100" class="h-[clamp(44px,6vw,60px)] w-auto" fill="currentColor" aria-hidden="true">
            <rect x="0" y="96" width="40" height="3" />
            <rect x="0" y="92" width="40" height="3" />
            <rect x="0" y="88" width="40" height="3" />
            <rect x="0" y="84" width="40" height="3" />
            <rect x="0" y="80" width="40" height="3" />
            <rect x="0" y="76" width="40" height="3" />
            <rect x="0" y="72" width="40" height="3" />
            <rect x="0" y="68" width="40" height="3" />
            <rect x="0" y="64" width="40" height="3" />
            <rect x="0" y="60" width="40" height="3" />
            <rect x="0" y="56" width="40" height="3" />
            <rect x="0" y="52" width="40" height="3" />
            <rect x="0" y="48" width="40" height="3" />
            <rect x="0" y="44" width="40" height="3" />
            <rect x="0" y="40" width="40" height="3" />
            <rect x="0" y="36" width="40" height="3" />
            <rect x="0" y="32" width="40" height="3" />
            <rect x="0" y="28" width="40" height="3" />
            <!-- Chamfer -->
            <rect x="0" y="24" width="36" height="3" />
            <rect x="0" y="20" width="32" height="3" />
            <rect x="0" y="16" width="28" height="3" />
            <rect x="0" y="12" width="24" height="3" />
            <rect x="0" y="8" width="20" height="3" />
            <rect x="0" y="4" width="16" height="3" />
            <rect x="0" y="0" width="12" height="3" />
          </svg>
        </div>

        <!-- Copyright Text -->
        <div class="flex flex-col text-left text-[clamp(18px,2.4vw,28px)] font-display font-black [font-variation-settings:'wght'_900,'wdth'_120] leading-[0.88] tracking-[-0.03em] uppercase select-none">
          <span>VALENTÍN PIGNATELLI</span>
          <span>© 2026 — BSAS</span>
        </div>
      </div>
    </div>

  </div>

  <!-- Giant wordmark PIGNATELLI at the very bottom, exactly full-width -->
  <div class="w-full overflow-hidden select-none pointer-events-none mt-6 flex-1 flex flex-col justify-end">
    <svg viewBox="0 0 1000 112" class="w-full h-auto block" preserveAspectRatio="none" aria-hidden="true">
      <text
        x="0" y="106"
        textLength="1000" lengthAdjust="spacingAndGlyphs"
        class="font-display font-black [font-variation-settings:'wght'_900,'wdth'_125] text-[132px] uppercase"
        fill="var(--color-ink)"
      >PIGNATELLI</text>
    </svg>
  </div>
</section>

<script>
  const btn = document.getElementById("copy-email");
  const label = document.getElementById("copy-email-label");
  let timer: ReturnType<typeof setTimeout> | undefined;

  if (btn && label) {
    btn.addEventListener("click", async () => {
      const email = btn.dataset.email ?? "";
      try {
        await navigator.clipboard.writeText(email);
        label.textContent = btn.dataset.copied ?? "";
        clearTimeout(timer);
        timer = setTimeout(() => {
          label.textContent = btn.dataset.label ?? "";
        }, 2000);
      } catch {
        // Clipboard unavailable (http, old browser): fall back to mailto
        window.location.href = `mailto:${email}`;
      }
    });
  }

  // Connect column "Email" link: copy instead of mailto
  document.querySelectorAll<HTMLAnchorElement>("a[data-copy-email]").forEach((link) => {
    let linkTimer: ReturnType<typeof setTimeout> | undefined;
    link.addEventListener("click", async (e) => {
      if (!navigator.clipboard) return; // no clipboard API: let the mailto href do its thing
      e.preventDefault();
      try {
        await navigator.clipboard.writeText(link.dataset.copyEmail ?? "");
        link.textContent = "Copied ✓";
        clearTimeout(linkTimer);
        linkTimer = setTimeout(() => {
          link.textContent = link.dataset.label ?? "";
        }, 2000);
      } catch {
        // Copy failed after preventing default: fall back to mailto manually
        window.location.href = link.href;
      }
    });
  });
</script>
